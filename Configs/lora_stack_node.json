      "type": "COMBO",
      "required": true,
      "source": "loras",
      "default": "None"
    },
    {
      "name": "model_weight_1",
      "type": "FLOAT",
      "required": true,
      "default": 1.0,
      "min": -10.0,
      "max": 10.0,
      "step": 0.01
    },
