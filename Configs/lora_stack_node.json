{
  "id": "LoRAStackNode",
  "name": "LoRA Stack \ud83d\uddc2\ufe0f",
  "category": "TensorVizion/Model Utilities",
  "description": "Chains up to 5 LoRAs with individual model and clip weights in a single node.",
