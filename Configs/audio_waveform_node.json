    {
      "name": "bg_color_r",
      "type": "INT",
      "required": true,
      "default": 5,
      "min": 0,
      "max": 255
    },
    {
      "name": "bg_color_g",
      "type": "INT",
      "required": true,
      "default": 10,
      "min": 0,
      "max": 255
