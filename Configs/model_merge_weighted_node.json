{
  "id": "ModelMergeWeightedNode",
  "name": "Model Merge Weighted \ud83d\udd00",
  "category": "TensorVizion/Model Utilities",
  "description": "Merges two diffusion models using weighted_sum, sigmoid_blend, or layer_select strategies.",
  "inputs": [
    {
      "name": "model_a",
      "type": "MODEL",
      "required": true
    },
    {
      "name": "model_b",
      "type": "MODEL",
      "required": true
    },
    {
      "name": "ratio",
      "type": "FLOAT",
      "required": true,
      "default": 0.5,
      "min": 0.0,
      "max": 1.0,
      "step": 0.01
    },
    {
      "name": "strategy",
      "type": "COMBO",
      "required": true,
      "options": [
        "weighted_sum",
        "sigmoid_blend",
        "layer_select"
      ],
      "default": "weighted_sum"
    }
  ],
  "outputs": [
    {
      "name": "merged_model",
      "type": "MODEL"
    }
  ],
  "function": "merge_models"
}